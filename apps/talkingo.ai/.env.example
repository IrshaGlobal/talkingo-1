# ─── Talkingo Web App — Environment Variables ─────────────────────────────────
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# Required for sign-in with Google. Create credentials in Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
# Add the redirect URI: https://yourdomain.com/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Server-side only (no NEXT_PUBLIC_ prefix)
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Appwrite ─────────────────────────────────────────────────────────────────
# Public (needed by client SDK)
NEXT_PUBLIC_APPWRITE_ENDPOINT=your_appwrite_endpoint_here
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id_here

# Server-side only (admin API key for webhook/notifications)
APPWRITE_API_KEY=your_appwrite_api_key_here

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Server-side only — required, validated at startup. App will throw on launch
# if any of these are missing or contain placeholder values.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs (different for test vs live mode)
STRIPE_PRICE_TRIAL=price_xxx
STRIPE_PRICE_MONTHLY=price_xxx
STRIPE_PRICE_YEARLY=price_xxx

# ─── DodoPayments ─────────────────────────────────────────────────────────────
# Alternative payment provider for emerging markets (UPI, PIX, iDEAL, etc.)
# Server-side only — required, validated at startup. App will throw on launch
# if any of these are missing or contain placeholder values.
DODOPAYMENTS_API_KEY=dodo_test_your_api_key_here
DODOPAYMENTS_WEBHOOK_SECRET=whsec_xxx

# DodoPayments Price IDs (different for test vs live mode)
DODOPAYMENTS_PRICE_MONTHLY=price_xxx
DODOPAYMENTS_PRICE_YEARLY=price_xxx

# ─── App Config ───────────────────────────────────────────────────────────────
# IMPORTANT: Update this to your production URL before deploying!
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Shared secret for admin → web cache invalidation
CACHE_INVALIDATION_SECRET=generate_a_strong_random_string_here

# ─── Required Appwrite collections ────────────────────────────────────────────
# Create these in your Appwrite console under database "talkingo_db":
#
#   subscriptions             (already required)
#   stripe_webhook_events     (NEW — webhook idempotency, doc id = stripe event id)
#       attributes: eventId (string), eventType (string), processedAt (int)
#   free_tier_usage           (NEW — daily counter, doc id = `${userId}_${date}`)
#       attributes: userId (string), date (string), count (int)
#
# If these collections don't exist the app falls back to in-memory tracking
# but you'll see warnings in the server logs.

# ========== Dodo Payments (Test Mode) ==========
# Base URLs: test.dodopayments.com (test), live.dodopayments.com (live)
# IMPORTANT: Keep keys only in local .env files, never commit real secrets.

# Dodo Payments API key (Test)
DODO_PAYMENTS_API_KEY=sk_test_replace_me

# Environment: "test_mode" or "live_mode"
DODO_PAYMENTS_ENVIRONMENT=test_mode

# Return URL after successful checkout (adjust to your app domain)
DODO_PAYMENTS_RETURN_URL=http://localhost:3000

# Webhook signing secret from Dodo Dashboard → Webhooks
DODO_PAYMENTS_WEBHOOK_SECRET=whsec_replace_me
